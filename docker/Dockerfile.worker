# anarcrypt.sol/anaheim-worker/docker/Dockerfile.worker
# ---- Stage 1: builder punk ----
FROM python:3.11-slim-bullseye AS builder

# ⚡ Installer les dépendances système pour builder les packages Python
RUN apt-get update && apt-get install -y \
    build-essential git curl wget unzip jq \
    && rm -rf /var/lib/apt/lists/*

# 🌀 Workdir temporaire pour le build
WORKDIR /tmp/build

# Copier requirements.txt seul pour cacher les couches si pas de changement
COPY src/requirements.txt .

# Installer Python packages dans un virtualenv isolé
RUN python -m venv /opt/venv \
    && /opt/venv/bin/pip install --upgrade pip \
    && /opt/venv/bin/pip install --no-cache-dir -r requirements.txt

# ---- Stage 2: final punk image ----
FROM python:3.11-slim-bullseye

# Dépendances runtime + config git globale
RUN apt-get update && apt-get install -y git curl wget unzip jq \
    && git config --global user.name "Orion-Worker" \
    && git config --global user.email "orion@local" \
    && rm -rf /var/lib/apt/lists/*

# 🏴‍☠️ Workdir du chaos
WORKDIR /work

# Copier venv depuis builder
COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copier code projet + scripts + config fixe pour worker
COPY src /work/src
COPY ../scripts /work/scripts
COPY ../config /work/config

# 🔑 Permissions punk
RUN chmod +x /work/scripts/start.sh

# 🔮 Variables d'environnement
ENV REPO_PATH=/work/project \
    GOV_PATH=/work/governance \
    DB_PATH=/work/data/memory.sqlite \
    PATCH_DIR=/work/data/patches \
    FIXES_JSON=/work/data/fixes.json \
    CFG_PATH=/work/config/worker_config.yml \
    LLM_CMD=gpt4all

# 🌐 Port exposé pour debug / Playwright
EXPOSE 9222

# 🎤 Entrypoint punk
ENTRYPOINT ["/work/scripts/start.sh"]
