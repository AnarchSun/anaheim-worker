# FILE: anarcrypt.sol/anaheim-worker/docker/Dockerfile.worker
# 🏴‍☠️ ANAHEIM-WORKER — CHAOTIC FRACTAL BUILDER / DEVNET MIRROR
# Pas de hardcode. Pas d’État. Pas d’esclavage. Seulement la vérité du code.

# ---- Stage 1: builder punk ----
FROM python:3.11-slim-bullseye AS builder

# ⚙️ System deps nécessaires pour build Playwright et outils Solana
RUN apt-get update && apt-get install -y \
    build-essential git curl wget unzip jq nodejs npm \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /tmp/build

# ⚡ Copy only requirements to leverage Docker cache
COPY src/requirements.txt .

# 🧠 Isolated virtualenv install
RUN python -m venv /opt/venv \
    && /opt/venv/bin/pip install --upgrade pip \
    && /opt/venv/bin/pip install --no-cache-dir -r requirements.txt

# ---- Stage 2: final punk image ----
FROM python:3.11-slim-bullseye

# 🧩 Runtime deps
RUN apt-get update && apt-get install -y \
    git curl wget unzip jq \
    # 🧠 playwright deps minimal set
    libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 libxkbcommon0 \
    libxcomposite1 libxdamage1 libxrandr2 libgbm1 libasound2 libxshmfence1 \
    && rm -rf /var/lib/apt/lists/*

# 👤 Git identity (no master, only rebel)
RUN git config --global user.name "Orion-Worker" \
    && git config --global user.email "orion@local"

# ⚔️ Workdir du chaos
WORKDIR /work

# 🔥 Copy venv from builder
COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# 📦 Copy project code, config, and scripts
COPY src /work/src
COPY ../config /work/config
COPY ../scripts /work/scripts

# 🗝️ Permissions punk
RUN chmod +x /work/scripts/start.sh

# 🌌 ENV configuration — no hardcode, only mirrored truth
ENV REPO_PATH=/work/project \
    GOV_PATH=/work/governance \
    DB_PATH=/work/data/memory.sqlite \
    PATCH_DIR=/work/data/patches \
    FIXES_JSON=/work/data/fixes.json \
    CFG_PATH=/work/config/worker_config.yml \
    SOLANA_CONFIG_PATH=/work/config/solana.yml \
    LLM_CMD=gpt4all

# 🌍 Network ports
EXPOSE 9222

# ☄️ Entrypoint — punkified launcher
ENTRYPOINT ["/work/scripts/start.sh"]
